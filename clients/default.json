{
  "client": "default",
  "detectionFloor": 8,
  "news": {
    "provider": "parallel",
    "lookbackDays": 180,
    "queries": [
      "\"{company}\" data breach OR ransomware OR security incident",
      "\"{company}\" CISO appointed OR hires OR \"chief information security officer\"",
      "\"{company}\" funding OR acquisition OR merger OR \"series b\" OR \"series c\""
    ]
  },
  "signalDefs": {
    "breach_announced":        { "base": 45, "bonusField": "ciso_identified",      "bonusPts": 5, "halfLifeDays": 30,  "label": "Breach/ransomware announced" },
    "hiring_ciso_and_iam":     { "base": 42, "bonusField": "competitor_in_jd",     "bonusPts": 5, "halfLifeDays": 45,  "label": "Hiring CISO + simultaneously hiring IAM engineer" },
    "soc2_and_compliance":     { "base": 40, "bonusField": "vanta_drata_detected", "bonusPts": 3, "halfLifeDays": 60,  "label": "SOC 2 audit in progress + hiring compliance role" },
    "cyber_insurance_funding": { "base": 38, "bonusField": "security_hire_open",   "bonusPts": 4, "halfLifeDays": 90,  "label": "Cyber insurance trigger + funding event" },
    "new_ciso_hired":          { "base": 35, "bonusField": "no_iam_vendor",        "bonusPts": 5, "halfLifeDays": 90,  "label": "New CISO hired (within 90 days)" },
    "funding_bc_soc2":         { "base": 33, "bonusField": "hiring_compliance",    "bonusPts": 4, "halfLifeDays": 90,  "label": "Funding (Series B/C) + SOC 2 pressure" },
    "competitor_in_jd":        { "base": 32, "bonusField": "multiple_postings",    "bonusPts": 5, "halfLifeDays": 45,  "label": "Competitor tool detected in job posting" },
    "cloud_migration":         { "base": 28, "bonusField": "security_hire_open",   "bonusPts": 4, "halfLifeDays": 120, "label": "Cloud migration announcement" },
    "ma_activity":             { "base": 28, "bonusField": "both_in_icp",          "bonusPts": 4, "halfLifeDays": 120, "label": "M&A activity announced" },
    "hiring_security_grc":     { "base": 25, "bonusField": "compliance_framework", "bonusPts": 3, "halfLifeDays": 45,  "label": "Hiring IT Security/GRC role" },
    "social_pain_post":        { "base": 22, "bonusField": "person_identified",    "bonusPts": 5, "halfLifeDays": 21,  "label": "Reddit/LinkedIn post about access pain" },
    "funding_a_only":          { "base": 18, "bonusField": "regulated_industry",   "bonusPts": 5, "halfLifeDays": 90,  "label": "Funding (Series A) only" },
    "content_consumption":     { "base": 15, "bonusField": "iam_pam_specific",     "bonusPts": 3, "halfLifeDays": 21,  "label": "Content consumption signal" }
  },
  "signalStacks": [
    { "signals": ["breach_announced", "hiring_ciso_and_iam"], "combined": 50, "label": "Breach disclosed + CISO role open",               "meaning": "In crisis mode AND rebuilding — perfect" },
    { "signals": ["new_ciso_hired", "competitor_in_jd"],       "combined": 47, "label": "New CISO hired + CyberArk/SailPoint job posting", "meaning": "New leader auditing the stack, budget confirmed" },
    { "signals": ["soc2_and_compliance", "funding_bc_soc2"],   "combined": 45, "label": "SOC 2 in progress + Vanta in JD + Series B",      "meaning": "Classic mid-market compliance-driven buyer" },
    { "signals": ["ma_activity", "hiring_security_grc"],       "combined": 43, "label": "PE acquisition + IAM/GRC role opening",           "meaning": "PE firm mandating controls post-acquisition" },
    { "signals": ["breach_announced", "hiring_security_grc"],  "combined": 43, "label": "HIPAA breach + hiring compliance manager",        "meaning": "Remediation mode = urgent buyer" },
    { "signals": ["funding_bc_soc2", "soc2_and_compliance"],   "combined": 40, "label": "Series C + enterprise customer demanding SOC 2",  "meaning": "Pipeline pressure = budget pressure" },
    { "signals": ["hiring_security_grc", "competitor_in_jd"],  "combined": 40, "label": "CMMC requirement + PAM job posting",              "meaning": "Federal contract at risk = non-negotiable buy" },
    { "signals": ["hiring_security_grc", "social_pain_post"],  "combined": 38, "label": "Hiring access management + LinkedIn pain post",   "meaning": "Problem confirmed at person level" }
  ],
  "tiers": [
    { "min": 35, "tier": "CRITICAL", "action": "24-48hr outreach",        "emoji": "🔴" },
    { "min": 28, "tier": "HIGH",     "action": "3-day / week 1 outreach", "emoji": "🟠" },
    { "min": 22, "tier": "MEDIUM",   "action": "Next batch",              "emoji": "🟡" },
    { "min": 15, "tier": "LOW",      "action": "Monitor list",            "emoji": "🟢" }
  ],
  "competitorCompanies": [
    { "name": "cyberark",       "slugs": ["cyberark"] },
    { "name": "beyondtrust",    "slugs": ["beyondtrust"] },
    { "name": "delinea",        "slugs": ["delinea"] },
