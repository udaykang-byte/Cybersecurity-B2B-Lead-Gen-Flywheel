# Copy this file to .env and fill in your values
# Never commit .env — it is gitignored

# ── Supabase (data layer — required for all scripts) ──
# Create a project at https://supabase.com, then go to Settings > API
# Run supabase/migrations/001_initial_schema.sql in the SQL editor first.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here   # Settings > API > service_role (secret)
SUPABASE_ANON_KEY=your-anon-key-here              # Settings > API > anon (public) — optional, for read-only use

# ── Apify (scraping — required for Reddit + LinkedIn scrapers) ──
# Used by: reddit-scraper.js, enrich-leads.js, linkedin-jobs.js, linkedin-people.js, linkedin-companies.js
# Get your token at https://console.apify.com > Settings > Integrations
APIFY_API_TOKEN=your_apify_token_here

# ── Parallel.ai (news + web research — primary news source for account-signals.js) ──
# Install the CLI: npm install -g parallel-web-cli   (brew install parallel-web/tap/parallel-cli also works)
# Then authenticate: parallel-cli login
# Or set the key directly:
PARALLEL_API_KEY=your_parallel_api_key_here
# If parallel-cli is not on PATH (e.g. lives in ~/.npm-global/bin), point to it:
# PARALLEL_CLI=/absolute/path/to/parallel-cli

# ── Optional: Perplexity Sonar API for deep Reddit prospect research ──
# Used by: enrich-leads.js --research
# Get your key at https://docs.perplexity.ai/
PERPLEXITY_API_KEY=your_perplexity_key_here

# ── Optional: Slack notifications for HOT leads ──
# Used by: notify.js, account-signals.js
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ── Optional: Exa.ai — alternative research engine for enrich-leads.js ──
# Used by: enrich-leads.js --exa (alternative to Perplexity); account-signals.js (secondary lookup)
# Get your key at https://exa.ai/
EXA_API_KEY=your_exa_api_key_here
